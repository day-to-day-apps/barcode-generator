# Uzupełnij wartościami z dashboardu Supabase (Settings → API)
# NIGDY nie commituj tego pliku z prawdziwymi wartościami.

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
